#!/usr/bin/env bash
# Post-stow hook for dctl package
# Prints build instructions after deployment

set -euo pipefail

warn() {
  printf '\033[1;33mWARNING:\033[0m %s\n' "$1" >&2
}

info() {
  printf '\033[1;34mINFO:\033[0m %s\n' "$1"
}

# Check for podman command (dctl uses rootless podman exclusively;
# see docs/specs/sandbox-runtime/DECISION-LINUX.md)
if ! command -v podman &>/dev/null; then
  warn "podman not found. Install podman to build devcontainer images."
  exit 0
fi

info "Dctl image definitions deployed to ~/.local/share/dctl/images/"
info "Build images with:"
printf '%s\n' ""
printf '%s\n' "  dctl image build --all"
printf '%s\n' ""
info "Workspace workflow:"
printf '%s\n' ""
printf '%s\n' "  dctl ws up                  # start current workspace container"
printf '%s\n' "  dctl ws reup                # recreate current workspace container"
printf '%s\n' "  dctl ws shell               # interactive shell"
printf '%s\n' "  dctl ws down                # stop/remove current workspace container(s)"
printf '%s\n' ""
info "Enable weekly auto-rebuild (Fridays 6pm):"
printf '%s\n' ""
printf '%s\n' "  systemctl --user daemon-reload"
printf '%s\n' "  systemctl --user enable --now dctl-image-build.timer"
printf '%s\n' ""
info "Documentation: docs/ARCHITECTURE.md"
