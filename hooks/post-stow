#!/usr/bin/env bash
# Post-stow hook for dctl package
# Prints build instructions after deployment

set -euo pipefail

warn() {
  printf '\033[1;33mWARNING:\033[0m %s\n' "$1" >&2
}

info() {
  printf '\033[1;34mINFO:\033[0m %s\n' "$1"
}

# Check for docker command
if ! command -v docker &>/dev/null; then
  warn "docker not found. Install docker to build devcontainer images."
  exit 0
fi

info "Dctl image definitions deployed to ~/.local/share/dctl/images/"
info "Build images with:"
echo ""
echo "  dctl image build --all"
echo ""
info "Workspace workflow:"
echo ""
echo "  dctl workspace up                  # start current workspace container"
echo "  dctl workspace reup                # recreate current workspace container"
echo "  dctl workspace shell               # interactive shell"
echo "  dctl workspace down                # stop/remove current workspace container(s)"
echo ""
info "Enable weekly auto-rebuild (Fridays 6pm):"
echo ""
echo "  systemctl --user daemon-reload"
echo "  systemctl --user enable --now dctl-image-build.timer"
echo ""
info "Documentation: docs/ARCHITECTURE.md"
