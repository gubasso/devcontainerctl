#!/usr/bin/env bash
# Unified devcontainer workspace and image management CLI

set -euo pipefail

DCTL_LIB_DIR="$(dirname "$(readlink -f "$0")")/../lib/dctl"
readonly DCTL_LIB_DIR

if [[ ! -d "$DCTL_LIB_DIR" ]]; then
  printf '\033[1;31mERROR:\033[0m dctl library not found at %s\n' "$DCTL_LIB_DIR" >&2
  exit 1
fi

# shellcheck source=/dev/null
source "${DCTL_LIB_DIR}/common.sh"
# shellcheck source=/dev/null
source "${DCTL_LIB_DIR}/workspace.sh"
# shellcheck source=/dev/null
source "${DCTL_LIB_DIR}/image.sh"

usage() {
  cat <<'EOF'
Usage: dctl <command-group> <command> [options]

Command groups:
  workspace    Manage the current workspace's devcontainer lifecycle
  image        Build and inspect devcontainer base images
  help         Show this help text
  version      Show dctl version

Examples:
  dctl workspace up
  dctl workspace shell
  dctl workspace run -- claude
  dctl image build --all
  dctl image list
EOF
}

main() {
  local command_group="${1:-help}"

  case "$command_group" in
    workspace)
      shift
      main_workspace "$@"
      ;;
    image)
      shift
      main_image "$@"
      ;;
    help | -h | --help)
      usage
      ;;
    version | -v | --version)
      printf 'dctl %s\n' "$DCTL_VERSION"
      ;;
    *)
      err "Unknown command group: $command_group"
      ;;
  esac
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  main "$@"
fi
