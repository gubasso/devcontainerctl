#!/usr/bin/env bash
# Unified devcontainer workspace and image management CLI

set -euo pipefail

DCTL_LIB_DIR="$(dirname "$(readlink -f "$0")")/../lib/dctl"
readonly DCTL_LIB_DIR

if [[ ! -d $DCTL_LIB_DIR ]]; then
  printf '\033[1;31mERROR:\033[0m dctl library not found at %s\n' "$DCTL_LIB_DIR" >&2
  exit 1
fi

source "${DCTL_LIB_DIR}/_lib/source.sh"
__dctl_require _lib/log.sh
__dctl_require _lib/paths.sh

usage() {
  cat <<'EOF'
Usage: dctl [--config <path>] <command-group> [command] [options]

Global options:
  --config <path>  Use a specific devcontainer.json

Commands:
  init         Register the current project using a deployed devcontainer
  deploy       Copy installed templates/images into user config
  test         Validate the current workspace setup
  doctor       Probe the host for libkrun + rootless Podman readiness
  ws           Manage the current workspace's devcontainer lifecycle
  image        Build and inspect devcontainer base images
  config       Project registry management
  help         Show this help text
  version      Show dctl version

Examples:
  dctl deploy --all
  dctl deploy devcontainer python
  dctl init --devcontainer python
  dctl test
  dctl ws up
  dctl ws shell
  dctl ws run -- claude-session
  dctl image build --all
  dctl image list
EOF
}

main() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --config)
        [[ $# -ge 2 ]] || err "--config requires a value"
        [[ -n $2 ]] || err "--config requires a non-empty path"
        export DCTL_CLI_CONFIG="$2"
        shift 2
        ;;
      help | -h | --help | version | -v | --version)
        break
        ;;
      --*)
        err "Unknown global option: $1"
        ;;
      *)
        break
        ;;
    esac
  done

  __dctl_dispatch "$@"
}

if [[ ${BASH_SOURCE[0]} == "$0" ]]; then
  main "$@"
fi
